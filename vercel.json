{
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://vdlphotographe.fr/$1",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "vdlphotographe.com"
        }
      ]
    },
    {
      "source": "/(.*)",
      "destination": "https://vdlphotographe.fr/$1",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "www.vdlphotographe.com"
        }
      ]
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/200.html" }
  ]
}
